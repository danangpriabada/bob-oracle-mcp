{
  "name": "bob-oracle-mcp",
  "version": "1.0.0",
  "description": "Production-ready Oracle Database MCP Server built with the Model Context Protocol SDK.",
  "type": "module",
  "main": "src/server.js",
  "author": "Danang Priabada",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "clean": "rm -rf logs/* coverage"
  },
  "keywords": [
    "mcp",
    "oracle",
    "oracledb",
    "database",
    "ai",
    "llm",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "dotenv": "^17.2.0",
    "oracledb": "^6.9.0",
    "pino": "^9.7.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "eslint": "^9.30.1",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2"
  }
}
